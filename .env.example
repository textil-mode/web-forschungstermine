# Kopiere zu .env (wird NICHT versioniert) und fülle die Werte.
APP_BASE=/forschungstermine
# Groq-Key (kostenloser Free Tier, https://console.groq.com/keys) für die
# KI-Extraktion. Leer = KI aus. Optional: GROQ_MODEL (Default llama-3.3-70b-versatile).
GROQ_API_KEY=

# E-Mail-Benachrichtigung bei neuen Unternehmens-Anfragen (Formular „Für
# Unternehmen"). Alle vier Pflichtwerte nötig, sonst wird nur in der DB
# gespeichert (kein Mailversand). MAIL_FROM optional (Default = SMTP_USER).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=

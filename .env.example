# Kopiere zu .env (wird NICHT versioniert) und fülle die Werte.
APP_BASE=/forschungstermine
# Groq-Key (kostenloser Free Tier, https://console.groq.com/keys) für die
# KI-Extraktion. Leer = KI aus. Optional: GROQ_MODEL (Default llama-3.3-70b-versatile).
GROQ_API_KEY=

# E-Mail-Benachrichtigung bei neuen Pitch-&-Connect-Anfragen — via AgentMail.
# Alle drei Werte nötig, sonst wird nur in der DB gespeichert (kein Mailversand).
# API-Key: console.agentmail.to -> API Keys. Inbox = Absender-Adresse.
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX=michaelschuckert@agentmail.to
MAIL_TO=mschuckert@textil-mode.de

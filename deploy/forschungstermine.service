[Unit]
Description=Forschungstermine FastAPI-Dienst
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/web-forschungstermine
EnvironmentFile=/opt/web-forschungstermine/.env
ExecStart=/opt/web-forschungstermine/.venv/bin/uvicorn app.api:app --host 127.0.0.1 --port 8095
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
